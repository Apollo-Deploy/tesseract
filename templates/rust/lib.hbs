//!
//! ```rust,no_run
//! use {{crateName}}::Client;
//! use {{crateName}}::ClientConfig;
//!
//! #[tokio::main]
//! async fn main() -> Result<(), Box<dyn std::error::Error>> {
//!     let mut config = ClientConfig::default();
{{#each securitySchemes}}
{{#if (eq type "apiKey")}}
